@page "/Pares"
@rendermode InteractiveServer

<h1>Listas de numeros</h1>

<label>Número 1</label><br />
<input type="number" @bind="num1" @bind:event="oninput" /><br /><br />

<label>Número 2</label><br />
<input type="number" @bind="num2" @bind:event="oninput" /><br /><br />

<button type="button" @onclick="Calcular">Calcular</button>

<div class="row mt-4">
    <div class="col-md-6">
        <h3>Pares</h3>
        <ul>
            @foreach (var p in pares)
            {
                <li>@p</li>
            }
        </ul>
    </div>

    <div class="col-md-6">
        <h3>Impares</h3>
        <ul>
            @foreach (var i in impares)
            {
                <li>@i</li>
            }
        </ul>
    </div>
</div>

@code {
    private int num1;
    private int num2;
    private List<int> pares = new();
    private List<int> impares = new();

    private void Calcular()
    {
        pares = new List<int>();
        impares = new List<int>();

        int inicio = Math.Min(num1, num2);
        int fin = Math.Max(num1, num2);

        for (int n = inicio; n <= fin; n++)
        {
            if (n % 2 == 0) pares.Add(n);
            else impares.Add(n);
        }
    }
}
